# Variables de entorno para el Dashboard de Diagnosis de Vehículos

# --- IA Generativa (Google Gemini) ---
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Sheets ---
# ID de la hoja de cálculo de Google Sheets donde se guardan los diagnósticos
# (extraer del enlace: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# Nombre de la hoja dentro del documento (por defecto: "Diagnosticos")
SHEET_NAME=Diagnosticos

# Ruta al fichero de credenciales de la cuenta de servicio de Google
# (descargar desde Google Cloud Console > IAM y administración > Cuentas de servicio)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# --- Flask ---
# Clave secreta para las sesiones de Flask (generar con: python -c "import secrets; print(secrets.token_hex())")
SECRET_KEY=your_flask_secret_key_here

# Modo debug (True en desarrollo, False en producción)
FLASK_DEBUG=True

# Puerto del servidor
PORT=5000
